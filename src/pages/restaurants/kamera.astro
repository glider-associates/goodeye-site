---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
  title="KAMERA | 焼売×お茶ハイ 渋谷・百軒店のネオ酒場 | good-eye"
  description="渋谷・百軒店の焼売×お茶ハイ専門ネオ酒場KAMERA。フレンチの熟成技法で仕上げた無添加焼売と、中国茶の専門家が監修したお茶ハイを立ち飲みカウンターで。"
>
  <Header />

  <main>
    <!-- ========== HERO ========== -->
    <section class="k-hero">
      <div class="k-hero-images">
        <div class="k-hero-main">
          <img src="/images/restaurants/kamera/kamera-01.jpg" alt="KAMERA" />
        </div>
        <div class="k-hero-sub">
          <img src="/images/restaurants/kamera/kamera-05.jpg" alt="KAMERA" />
        </div>
      </div>
      <div class="k-hero-overlay"></div>
      <div class="k-hero-content">
        <div class="k-hero-logo">
          <img src="/images/logos/kamera/kamera-logo.png" alt="KAMERA" />
        </div>
        <p class="k-hero-tagline">焼売とお茶ハイのネオ酒場</p>
        <div class="k-hero-scroll">
          <span class="k-hero-scroll-text">Scroll</span>
          <span class="k-hero-scroll-line"></span>
        </div>
      </div>
    </section>

    <!-- ========== CONCEPT ========== -->
    <section class="k-section k-concept">
      <div class="container">
        <div class="k-concept-inner fade-in">
          <div class="k-concept-text">
            <span class="section-label" style="color: var(--color-accent);">Concept</span>
            <h2 class="k-concept-heading">
              百軒店の青い灯のもと、<br />
              一杯目はここから。
            </h2>
            <p class="k-concept-desc">
              渋谷・百軒店の一角、青いネオンサインが目印のKAMERA。フレンチの熟成技法で仕上げた無添加の焼売と、中国茶の専門家が監修したお茶ハイを、立ち飲みカウンターで楽しむネオ酒場です。カジュアルに、でもクオリティは妥協しない。ふらっと立ち寄れる、街に馴染んだ一杯目の店。
            </p>
          </div>
          <div class="k-concept-img">
            <img src="/images/restaurants/kamera/kamera-08.jpg" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ========== MENU ========== -->
    <section class="k-section k-menu">
      <div class="container">
        <div class="k-section-header fade-in">
          <span class="section-label" style="color: var(--color-accent);">Menu</span>
          <h2 class="section-title-en" style="color: var(--color-white);">Signature</h2>
          <p class="section-title-ja" style="color: var(--color-text-light-gray);">看板メニュー</p>
        </div>

        <div class="k-menu-grid">
          <!-- 焼売 -->
          <div class="k-menu-card fade-in">
            <div class="k-menu-card-img">
              <img src="/images/restaurants/kamera/kamera-06.jpg" alt="焼売" loading="lazy" />
            </div>
            <div class="k-menu-card-body">
              <span class="k-menu-card-label">Shumai</span>
              <h3 class="k-menu-card-title">熟成焼売</h3>
              <p class="k-menu-card-desc">
                化学調味料を使わず、フレンチの熟成技法で旨味を引き出した無添加焼売。山形豚の熟成焼売、子羊と黒米の熟成焼売、蟹といくらの焼売など、素材ごとの個性を最大限に活かした5種のラインナップ。
              </p>
              <div class="k-menu-items">
                <span class="k-menu-item">山形豚の熟成焼売</span>
                <span class="k-menu-item">子羊と黒米の熟成焼売</span>
                <span class="k-menu-item">蟹といくらの焼売</span>
                <span class="k-menu-item">水焼売</span>
              </div>
            </div>
          </div>

          <!-- お茶ハイ -->
          <div class="k-menu-card fade-in">
            <div class="k-menu-card-img">
              <img src="/images/restaurants/kamera/kamera-07.jpg" alt="お茶ハイ" loading="lazy" />
            </div>
            <div class="k-menu-card-body">
              <span class="k-menu-card-label">Tea-Hai</span>
              <h3 class="k-menu-card-title">お茶ハイ</h3>
              <p class="k-menu-card-desc">
                中国茶の専門家が茶葉選定から淹れ方まで監修。福岡の麦焼酎蔵で造ったオリジナル焼酎をベースに、3種の定番ウーロンハイと季節のお茶ハイを合わせた10種以上のラインナップ。
              </p>
              <div class="k-menu-items">
                <span class="k-menu-item">四季春</span>
                <span class="k-menu-item">鳳凰単叢</span>
                <span class="k-menu-item">岩茶武夷水仙</span>
                <span class="k-menu-item">＋ 季節のお茶ハイ</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== GALLERY ========== -->
    <section class="k-section k-gallery">
      <div class="k-gallery-header fade-in">
        <div class="container">
          <span class="section-label" style="color: var(--color-accent);">Gallery</span>
          <h2 class="section-title-en" style="color: var(--color-text-dark);">Atmosphere</h2>
          <p class="section-title-ja">店内の雰囲気</p>
        </div>
      </div>
      <div class="k-gallery-grid fade-in">
        <div class="k-gallery-item k-gallery-wide">
          <img src="/images/restaurants/kamera/kamera-09.jpg" alt="" loading="lazy" />
        </div>
        <div class="k-gallery-item">
          <img src="/images/restaurants/kamera/kamera-10.jpg" alt="" loading="lazy" />
        </div>
        <div class="k-gallery-item">
          <img src="/images/restaurants/kamera/kamera-03.jpg" alt="" loading="lazy" />
        </div>
        <div class="k-gallery-item k-gallery-wide">
          <img src="/images/restaurants/kamera/kamera-11.jpg" alt="" loading="lazy" />
        </div>
        <div class="k-gallery-item">
          <img src="/images/restaurants/kamera/kamera-02.jpg" alt="" loading="lazy" />
        </div>
        <div class="k-gallery-item">
          <img src="/images/restaurants/kamera/kamera-04.jpg" alt="" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ========== INFO ========== -->
    <section class="k-section k-info">
      <div class="container">
        <div class="k-info-inner fade-in">
          <div class="k-info-content">
            <span class="section-label" style="color: var(--color-accent);">Information</span>
            <h2 class="section-title-en" style="color: var(--color-white);">Access</h2>
            <p class="section-title-ja" style="color: var(--color-text-light-gray);">店舗情報</p>

            <dl class="k-info-list">
              <div class="k-info-row">
                <dt>店舗名</dt>
                <dd>KAMERA（カメラ）</dd>
              </div>
              <div class="k-info-row">
                <dt>住所</dt>
                <dd>〒150-0043<br />東京都渋谷区道玄坂2-20-5 1F</dd>
              </div>
              <div class="k-info-row">
                <dt>アクセス</dt>
                <dd>渋谷駅 徒歩5分 / 神泉駅 徒歩4分</dd>
              </div>
              <div class="k-info-row">
                <dt>営業時間</dt>
                <dd>17:00〜24:00</dd>
              </div>
              <div class="k-info-row">
                <dt>定休日</dt>
                <dd>不定休</dd>
              </div>
            </dl>

            <div class="k-info-links">
              <a href="https://www.instagram.com/kamera_shibuya/" target="_blank" rel="noopener" class="k-info-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <circle cx="12" cy="12" r="5" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
                <span>@kamera_shibuya</span>
              </a>
            </div>
          </div>

          <div class="k-info-map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3241.7!2d139.693!3d35.657!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z5p2x5Lqs6YO95riL6LC35Yy66YGT546E5Z2CMTI!5e0!3m2!1sja!2sjp!4v1!5m2!1sja!2sjp"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== OTHER RESTAURANTS ========== -->
    <section class="k-section k-others">
      <div class="container">
        <div class="k-section-header fade-in">
          <span class="section-label" style="color: var(--color-accent);">Other Restaurants</span>
          <h2 class="section-title-en" style="color: var(--color-white);">Our Restaurants</h2>
        </div>

        <div class="k-others-grid">
          <a href="/restaurants/tenki" class="k-others-card fade-in">
            <div class="k-others-card-img">
              <img src="/images/restaurants/tenki/tenki-01.jpg" alt="テンキ" loading="lazy" />
              <div class="k-others-card-overlay"></div>
            </div>
            <div class="k-others-card-body">
              <h3 class="k-others-card-name">テンキ</h3>
              <p class="k-others-card-desc">天ぷら×白ワイン</p>
            </div>
          </a>

          <a href="/restaurants/rinn" class="k-others-card fade-in">
            <div class="k-others-card-img">
              <img src="/images/restaurants/rinn/rinn-01.jpg" alt="RINN" loading="lazy" />
              <div class="k-others-card-overlay"></div>
            </div>
            <div class="k-others-card-body">
              <h3 class="k-others-card-name">RINN</h3>
              <p class="k-others-card-desc">ロティサリーチキン×クラフト焼酎</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== CTA ========== -->
    <section class="k-section k-cta">
      <div class="k-cta-bg">
        <img src="/images/restaurants/kamera/kamera-04.jpg" alt="" loading="lazy" />
        <div class="k-cta-overlay"></div>
      </div>
      <div class="container">
        <div class="k-cta-content fade-in">
          <p class="k-cta-text">KAMERAで一緒に働きませんか？</p>
          <a href="/recruit" class="btn" style="color: var(--color-white);">
            <span>Recruit</span>
            <span class="btn-arrow"></span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== HERO ===== */
  .k-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  .k-hero-images {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 3fr 2fr;
  }

  .k-hero-main,
  .k-hero-sub {
    overflow: hidden;
  }

  .k-hero-main img,
  .k-hero-sub img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .k-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.4) 0%,
      rgba(10, 10, 10, 0.7) 100%
    );
    z-index: 1;
  }

  .k-hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .k-hero-logo img {
    height: clamp(40px, 6vw, 60px);
    width: auto;
    filter: brightness(0) invert(1);
    margin-bottom: 1.5rem;
  }

  .k-hero-tagline {
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.2em;
    font-weight: 300;
  }

  .k-hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .k-hero-scroll-text {
    font-family: var(--font-en);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
  }

  .k-hero-scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollLine 1.5s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ===== SECTIONS ===== */
  .k-section {
    padding: var(--section-padding) 0;
  }

  .k-section-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ===== CONCEPT ===== */
  .k-concept {
    background: var(--color-bg-dark);
  }

  .k-concept-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .k-concept-heading {
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-white);
    line-height: 2;
    letter-spacing: 0.08em;
    margin: 1rem 0 2rem;
  }

  .k-concept-desc {
    font-size: 0.85rem;
    line-height: 2.2;
    color: var(--color-text-light-gray);
    font-weight: 300;
    letter-spacing: 0.03em;
  }

  .k-concept-img {
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .k-concept-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .k-concept-img:hover img {
    transform: scale(1.03);
  }

  /* ===== MENU ===== */
  .k-menu {
    background: var(--color-bg-dark);
    border-top: 1px solid var(--color-border);
  }

  .k-menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .k-menu-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color 0.4s ease;
  }

  .k-menu-card:hover {
    border-color: var(--color-accent);
  }

  .k-menu-card-img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .k-menu-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .k-menu-card:hover .k-menu-card-img img {
    transform: scale(1.04);
  }

  .k-menu-card-body {
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .k-menu-card-label {
    font-family: var(--font-en);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .k-menu-card-title {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: 0.06em;
    margin-bottom: 1.2rem;
  }

  .k-menu-card-desc {
    font-size: 0.82rem;
    line-height: 2;
    color: var(--color-text-light-gray);
    font-weight: 300;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .k-menu-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .k-menu-item {
    font-size: 0.72rem;
    padding: 5px 14px;
    border: 1px solid var(--color-border);
    color: var(--color-text-light-gray);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* ===== GALLERY ===== */
  .k-gallery {
    background: var(--color-bg-light);
  }

  .k-gallery-header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .k-gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  .k-gallery-item {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .k-gallery-item.k-gallery-wide {
    grid-column: span 2;
    aspect-ratio: 2 / 1;
  }

  .k-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .k-gallery-item:hover img {
    transform: scale(1.04);
  }

  /* ===== INFO ===== */
  .k-info {
    background: var(--color-bg-dark);
  }

  .k-info-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .k-info-list {
    margin-top: clamp(2rem, 3vw, 3rem);
  }

  .k-info-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .k-info-row dt {
    font-size: 0.78rem;
    color: var(--color-text-light-gray);
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .k-info-row dd {
    font-size: 0.82rem;
    color: var(--color-white);
    font-weight: 300;
    line-height: 1.8;
    letter-spacing: 0.03em;
  }

  .k-info-links {
    margin-top: 2rem;
  }

  .k-info-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-white);
    font-family: var(--font-en);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .k-info-link:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .k-info-map {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .k-info-map iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(0.8) brightness(0.7);
    transition: filter 0.4s ease;
  }

  .k-info-map:hover iframe {
    filter: grayscale(0) brightness(1);
  }

  /* ===== OTHER RESTAURANTS ===== */
  .k-others {
    background: var(--color-bg-dark);
    border-top: 1px solid var(--color-border);
  }

  .k-others-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 2rem);
  }

  .k-others-card {
    position: relative;
    overflow: hidden;
    display: block;
  }

  .k-others-card-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .k-others-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .k-others-card:hover .k-others-card-img img {
    transform: scale(1.05);
  }

  .k-others-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 10, 0.8) 0%,
      rgba(10, 10, 10, 0.1) 60%
    );
  }

  .k-others-card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: clamp(1rem, 2vw, 2rem);
    z-index: 1;
  }

  .k-others-card-name {
    font-family: var(--font-en);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 300;
    color: var(--color-white);
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }

  .k-others-card-desc {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  /* ===== CTA ===== */
  .k-cta {
    position: relative;
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .k-cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .k-cta-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .k-cta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.7);
  }

  .k-cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .k-cta-text {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--color-white);
    letter-spacing: 0.08em;
    font-weight: 300;
    margin-bottom: 2rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .k-hero-images {
      grid-template-columns: 1fr;
    }

    .k-hero-sub {
      display: none;
    }

    .k-concept-inner {
      grid-template-columns: 1fr;
    }

