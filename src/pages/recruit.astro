---
import Layout from "../layouts/Layout.astro";
import RecruitHeader from "../components/RecruitHeader.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="採用情報 | good-eye"
  description="株式会社good-eyeの採用情報。カルチャーをつくる仕事、一緒に挑戦する仲間を募集しています。"
>
  <RecruitHeader />

  <main>
    <!-- ========== HERO ========== -->
    <section class="r-hero">
      <div class="r-hero-bg">
        <img src="/images/restaurants/rinn/rinn-01.jpg" alt="" />
        <div class="r-hero-overlay"></div>
      </div>

      <div class="r-hero-ticker">
        <div class="ticker-track">
          <span class="ticker-item">食と街で、新しい景色をつくる。</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">Join good-eye</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">カルチャーをつくる仕事</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">食と街で、新しい景色をつくる。</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">Join good-eye</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">カルチャーをつくる仕事</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">食と街で、新しい景色をつくる。</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">Join good-eye</span>
          <span class="ticker-sep">/</span>
          <span class="ticker-item">カルチャーをつくる仕事</span>
          <span class="ticker-sep">/</span>
        </div>
      </div>

      <div class="r-hero-content">
        <p class="r-hero-label">good-eye recruit</p>
        <h1 class="r-hero-heading">
          カルチャーを<br />つくる仕事
        </h1>
      </div>

      <nav class="r-hero-nav">
        <a href="#message">Message</a>
        <a href="#culture">Culture</a>
        <a href="#people">People</a>
        <a href="#ceo-message">Top Message</a>
        <a href="#faq">FAQ</a>
        <a href="#positions">募集情報</a>
      </nav>
    </section>

    <!-- ========== MESSAGE ========== -->
    <section class="r-section r-message" id="message">
      <div class="container">
        <div class="r-section-header fade-in">
          <span class="r-section-label">Message</span>
          <h2 class="r-section-title">good-eyeの想い</h2>
        </div>

        <div class="r-message-body fade-in">
          <div class="r-message-main">
            <p class="r-message-philosophy">
              good-eyeが大切にしているのは、<br />
              <strong>「食と街で、新しい景色をつくる」</strong>こと。
            </p>

            <p class="r-message-text">
              私たちは渋谷という街を拠点に、フランス料理の技法を居酒屋業態に落とし込んだ独自の飲食店を運営しています。ただ料理を提供するだけではなく、その場所でしか生まれない体験、空気、カルチャーをつくることが私たちの仕事です。
            </p>
            <p class="r-message-text">
              デジタルマーケティングの知見と飲食業の実践知を掛け合わせ、両軸の相乗効果によって新たな価値を生み出す。既存の枠にとらわれず、街に根ざしながらも新しい景色を見せ続けること。それが good-eye のミッションです。
            </p>
            <p class="r-message-text">
              一緒にこの挑戦をしてくれる仲間を探しています。
            </p>
          </div>

          <div class="r-message-values">
            <div class="r-value-card">
              <span class="r-value-num">01</span>
              <p class="r-value-text">渋谷を代表する店をつくる</p>
            </div>
            <div class="r-value-card">
              <span class="r-value-num">02</span>
              <p class="r-value-text">食を通じてカルチャーを創造する</p>
            </div>
            <div class="r-value-card">
              <span class="r-value-num">03</span>
              <p class="r-value-text">一人ひとりが主役になれる組織</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CULTURE ========== -->
    <section class="r-section r-culture" id="culture">
      <div class="r-culture-visual">
        <img src="/images/restaurants/kamera/kamera-02.jpg" alt="" loading="lazy" />
        <div class="r-culture-visual-overlay"></div>
        <div class="r-culture-visual-text">
          <span class="r-section-label" style="color: var(--color-accent-light);">Culture</span>
          <h2 class="r-culture-visual-heading">
            「街」と「食」の<br />リアルプレイスで<br />活躍する
          </h2>
        </div>
      </div>

      <div class="container">
        <div class="r-culture-grid">
          <div class="r-culture-item fade-in">
            <div class="r-culture-item-img">
              <img src="/images/restaurants/tenki/tenki-01.jpg" alt="" loading="lazy" />
            </div>
            <div class="r-culture-item-body">
              <h3 class="r-culture-item-title">少数精鋭のチーム</h3>
              <p class="r-culture-item-desc">
                good-eyeは大企業ではありません。だからこそ、一人ひとりの声が届き、意見がすぐにカタチになる。やりたいことを自分の手で実現できる環境がここにはあります。オーナーシップを持って仕事に取り組める方を求めています。
              </p>
            </div>
          </div>

          <div class="r-culture-item reverse fade-in">
            <div class="r-culture-item-img">
              <img src="/images/restaurants/kamera/kamera-01.jpg" alt="" loading="lazy" />
            </div>
            <div class="r-culture-item-body">
              <h3 class="r-culture-item-title">3つの個性が共存する環境</h3>
              <p class="r-culture-item-desc">
                KAMERAの焼売×お茶ハイのネオ酒場、テンキの天ぷらと300種のナチュラルワイン、RINNのロティサリーチキン×クラフト焼酎——業態もお客様も異なる3店舗が、それぞれの個性を磨きながら共存しています。1社にいながら多様な飲食体験に携われる、他にはない成長環境です。
              </p>
            </div>
          </div>

          <div class="r-culture-item fade-in">
            <div class="r-culture-item-img">
              <img src="/images/restaurants/rinn/rinn-02.jpg" alt="" loading="lazy" />
            </div>
            <div class="r-culture-item-body">
              <h3 class="r-culture-item-title">デジタルとの相乗効果</h3>
              <p class="r-culture-item-desc">
                good-eyeはデジタルマーケティングのコンサルティング業も展開しています。SNSマーケティングやブランディングの知見を飲食店運営に活かし、「いい料理をつくる」だけでなく「届ける力」も武器にできる。他の飲食企業にはない、ユニークなキャリアパスがあります。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== PEOPLE ========== -->
    <section class="r-section r-people" id="people">
      <!-- 装飾ヒーロー画像 -->
      <div class="r-people-visual">
        <img src="/images/recruit-hero.jpg" alt="" loading="lazy" />
        <div class="r-people-visual-overlay"></div>
        <div class="r-people-visual-text">
          <span class="r-section-label" style="color: var(--color-accent-light);">People</span>
          <h2 class="r-people-visual-heading">good-eyeの人</h2>
          <p class="r-people-visual-sub">一緒に働く仲間の声をお届けします</p>
        </div>
      </div>

      <div class="container">
        <!-- Interview 01: KAMERA キッチンスタッフ -->
        <div class="r-interview fade-in">
          <div class="r-interview-intro">
            <span class="r-interview-num">Interview 01</span>
            <h3 class="r-interview-role">キッチンスタッフ — KAMERA</h3>
            <p class="r-interview-profile">居酒屋・中華料理店を経験後、2023年入社。渋谷・百軒店勤務。</p>
          </div>

          <div class="r-qa-block">
            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/kamera/kamera-01.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">KAMERAに入ったきっかけは？</p>
                <p class="r-qa-answer">
                  もともと中華で点心をやっていたんですが、KAMERAの焼売を食べて衝撃を受けました。フレンチの熟成技法で化学調味料なしにこの旨味を出しているのかと。立ち飲みカウンター越しにお客さんの反応がダイレクトに返ってくる距離感も魅力で、ここなら面白いことができると感じました。
                </p>
              </div>
            </div>

            <div class="r-qa-row reverse fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/kamera/kamera-03.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">KAMERAの好きなところは？</p>
                <p class="r-qa-answer">
                  百軒店の青いネオンの下で、焼売を蒸してお茶ハイと一緒に出した瞬間の「うまい！」が一番の喜びです。山形豚の熟成焼売や子羊と黒米の焼売のように、定番の焼売もフレンチのアプローチで進化させていく。お茶ハイに合う新作を考えたり、中国茶の監修をしている専門家と話したり。少人数だからこそアイデアがすぐ形になります。
                </p>
              </div>
            </div>

            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/kamera/kamera-02.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">今後の目標は？</p>
                <p class="r-qa-answer">
                  KAMERAの焼売を「渋谷といえばこれ」と言ってもらえる名物にしたいです。立ち飲みのライブ感をもっと活かして、百軒店にふらっと来た人が青いネオンに誘われて入ってしまう——そんな場所にしていきたいですね。
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- 区切り -->
        <div class="r-interview-divider"></div>

        <!-- Interview 02: テンキ ホール -->
        <div class="r-interview fade-in">
          <div class="r-interview-intro">
            <span class="r-interview-num">Interview 02</span>
            <h3 class="r-interview-role">ホールスタッフ — テンキ</h3>
            <p class="r-interview-profile">ソムリエ資格取得を目指して2024年入社。渋谷・桜丘町勤務。</p>
          </div>

          <div class="r-qa-block">
            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/tenki/tenki-01.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">テンキを選んだ理由は？</p>
                <p class="r-qa-answer">
                  桜丘町の看板のない隠れ家に入って、大谷石とヨーロピアンスタイルが融合した空間に一目惚れしました。天ぷらと白ワインという組み合わせに最初は驚きましたが、名物の海老天——エビつみれでエビを包んで、ビール発酵生地で揚げてフレンチソースで食べる——を口にして衝撃を受けました。約300種のナチュラルワインを扱う環境でソムリエを目指したいと思ったのがきっかけです。
                </p>
              </div>
            </div>

            <div class="r-qa-row reverse fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/tenki/tenki-02.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">テンキの接客で大事にしていることは？</p>
                <p class="r-qa-answer">
                  ビブグルマン経歴のシェフが揚げたての天ぷらを出してくれる瞬間に、ぴったりのナチュラルワインを合わせて提案する——その一連の流れが好きです。テンキは高級感がありつつもリラックスできる空間なので、かしこまりすぎず、でも丁寧に。カウンター越しにお客様の表情が見えるから、「今日来てよかった」を引き出せた瞬間がわかるんです。
                </p>
              </div>
            </div>

            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/tenki/tenki-03.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">今後の目標は？</p>
                <p class="r-qa-answer">
                  ソムリエの資格を取って、テンキの300種のワインリストを自分で構成できるようになりたいです。創作天ぷらとナチュラルワインのペアリングをもっと深めて、テンキならではの食体験を発信していきたい。将来はワインの仕入れルートの開拓にも関わりたいですね。
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- 区切り -->
        <div class="r-interview-divider"></div>

        <!-- Interview 03: RINN ホール -->
        <div class="r-interview fade-in">
          <div class="r-interview-intro">
            <span class="r-interview-num">Interview 03</span>
            <h3 class="r-interview-role">ホールスタッフ — RINN</h3>
            <p class="r-interview-profile">飲食未経験からスタート。2025年オープニング入社。渋谷・神泉勤務。</p>
          </div>

          <div class="r-qa-block">
            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/rinn/rinn-02.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">RINNの魅力は？</p>
                <p class="r-qa-answer">
                  フランス製のロティサリーマシンがぐるぐる回っていて、チキンの焼ける香りがお店中に広がっているんです。入った瞬間にテンションが上がる。全国から集めた50種以上のクラフト焼酎とのペアリングも面白くて、お客さんと「これ合う！」って盛り上がれる。友達にも「うちの店来てよ」って自信を持って言えます。
                </p>
              </div>
            </div>

            <div class="r-qa-row reverse fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/rinn/rinn-04.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">オープニングスタッフとしてどうでしたか？</p>
                <p class="r-qa-answer">
                  RINNの名前の由来が「輪・音・回転・年輪」で、火を囲んで人が一体になる場所っていうコンセプトに共感して飛び込みました。飲食未経験で正直不安でしたけど、KAMERAやテンキのスタッフも助けてくれて。オープニングからみんなで店をつくっていく感覚は、他では味わえない経験です。
                </p>
              </div>
            </div>

            <div class="r-qa-row fade-in">
              <div class="r-qa-img">
                <img src="/images/restaurants/rinn/rinn-03.jpg" alt="" loading="lazy" />
              </div>
              <div class="r-qa-content">
                <p class="r-qa-question">今後の目標は？</p>
                <p class="r-qa-answer">
                  まずはクラフト焼酎の知識をもっと深めて、お客さんに合った一杯を自信を持って提案できるようになりたいです。RINNはまだオープンしたばかりで、これからカルチャーを一緒につくっていける。いずれはRINNを任せてもらえるようになりたいですね。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TOP MESSAGE ========== -->
    <section class="r-section r-ceo" id="ceo-message">
      <div class="r-ceo-bg">
        <img src="/images/restaurants/kamera/kamera-04.jpg" alt="" loading="lazy" />
        <div class="r-ceo-bg-overlay"></div>
      </div>
      <div class="container">
        <div class="r-ceo-content fade-in">
          <span class="r-section-label" style="color: var(--color-accent-light);">Top Message</span>
          <h2 class="r-ceo-title">代表メッセージ</h2>
          <p class="r-ceo-name">
            <span class="r-ceo-name-ja">目良 慶太</span>
            <span class="r-ceo-name-role">代表取締役</span>
          </p>

          <div class="r-ceo-body">
            <p class="r-ceo-lead">
              「渋谷を代表する店をつくる」<br />
              その想いから、good-eyeは始まりました。
            </p>
            <p class="r-ceo-text">
              2015年の設立以来、私たちはデジタルマーケティングと飲食業という、一見異なる2つの領域で事業を展開してきました。しかし、その根底にあるのは「人が集まる場をつくり、カルチャーを生む」という一つの想いです。
            </p>
            <p class="r-ceo-text">
              KAMERAの青いネオンの下で焼売とお茶ハイを楽しむ百軒店の空気感。テンキの看板のない隠れ家で天ぷらとナチュラルワインが生む上質なひととき。RINNのフランス製ロティサリーマシンを囲んでクラフト焼酎を傾ける神泉の新しい夜——それぞれの店舗には、それぞれの個性と物語があります。渋谷の街に根ざした場所をつくってきました。お客様にとって、日常の延長線上にありながらも特別な時間を過ごせる場所。私たちが目指すのは、そんな飲食店です。
            </p>
            <p class="r-ceo-text">
              good-eyeに必要なのは、「食が好き」「街が好き」「何か新しいことをつくりたい」という気持ちを持った人です。経験やスキルは後からついてきます。大切なのは、この想いに共感してくれること。
            </p>
            <p class="r-ceo-text">
              まずは、お店に飲みに来てください。<br />
              そこで感じた空気が、あなたの答えになるはずです。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section class="r-section r-faq" id="faq">
      <div class="container">
        <div class="r-section-header fade-in">
          <span class="r-section-label">FAQ</span>
          <h2 class="r-section-title">よくある質問</h2>
        </div>

        <div class="r-faq-list fade-in">
          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">共通</span>
              応募から採用までの流れを教えてください
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>正社員の方は1〜2回の面接を経て内定となります。アルバイトの方は店舗スタッフとの1回の面接です。まずはお気軽にご連絡ください。</p>
            </div>
          </details>

          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">共通</span>
              飲食未経験でも応募できますか？
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>もちろんです。未経験からスタートしたスタッフも多数活躍しています。先輩スタッフが丁寧にサポートしますのでご安心ください。</p>
            </div>
          </details>

          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">共通</span>
              面接時の服装や持ち物は？
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>服装は自由です。履歴書をご持参ください。</p>
            </div>
          </details>

          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">社員</span>
              昇給制度はありますか？
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>定期的な評価・昇給の機会があります。実力と成果を正当に評価する体制を整えています。</p>
            </div>
          </details>

          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">社員</span>
              勤務地はどこですか？
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>渋谷区内の各店舗（KAMERA / テンキ / RINN）が勤務地となります。配属は本人の希望と適性を考慮して決定します。</p>
            </div>
          </details>

          <details class="r-faq-item">
            <summary class="r-faq-q">
              <span class="r-faq-badge">バイト</span>
              アルバイトから社員になれますか？
              <span class="r-faq-icon"></span>
            </summary>
            <div class="r-faq-a">
              <p>大歓迎です。アルバイトから正社員になったスタッフも在籍しています。ステップアップを応援する環境です。</p>
